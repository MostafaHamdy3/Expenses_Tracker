{
  "expo": {
    "name": "ExpenseTracker",
    "slug": "ExpenseTracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./app/assets/icons/Expenses_logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./app/assets/icons/Expenses_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.mostafa7amdy.ExpenseTracker"
    },
    "web": {
      "favicon": "./app/assets/icons/logo.png"
    },
    "extra": {},
    "plugins": [
      "expo-splash-screen",
      "expo-font",
      "expo-localization",
      "expo-asset"
    ]
  }
}
